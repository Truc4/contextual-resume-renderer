<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="file://{{ template_dir }}/style.css">
  <title>Resume</title>
</head>
<body>

<header>
  <div class="header-title">
    {{ name or "Your Name" }}
    {% if position %} - {{ position }}{% endif %}
  </div>
  {% if location %}<div class="header-location">{{ location }}</div>{% endif %}
  <div class="header-contact">
    {% if email %}{{ email }}{% endif %}
    {% if phone %}{{ " | " }}{{ phone }}{% endif %}
    {% if github %}<span> | <a href="{{ github }}">{{ github.replace('https://', '').replace('http://', '') }}</a></span>{% endif %}
    {% if linkedin %}<span> | <a href="{{ linkedin }}">{{ linkedin.replace('https://', '').replace('http://', '') }}</a></span>{% endif %}
    {% if portfolio %}<span> | <a href="{{ portfolio }}">{{ portfolio.replace('https://', '').replace('http://', '') }}</a></span>{% endif %}
  </div>
</header>

<!-- SUMMARY -->
{% if summaries %}
<section>
  <h2>SUMMARY</h2>
  <p>{{ summaries | join(" ") }}</p>
</section>
{% endif %}

<!-- SKILLS -->
{% if skills %}
<section>
  <h2>SKILLS</h2>
  <p>{{ skills | join(", ") }}</p>
</section>
{% endif %}

<!-- WORK EXPERIENCE -->
<section>
  <h2>WORK EXPERIENCE</h2>

  {% for job in jobs %}
  <div class="job">
    <div class="job-header">
      <div class="job-company">{{ job.company }}</div>
      <div class="job-dates">{{ job.dates }}</div>
    </div>
    <div class="job-role">{{ job.role }}</div>
    <ul class="job-bullets">
      {% for bullet in job.bullets %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}

</section>

<!-- EDUCATION -->
{% if education %}
<section>
  <h2>EDUCATION</h2>
  <p>
    {% if education.bachelor %}{{ education.bachelor }}{% endif %}
  </p>
</section>
{% endif %}

</body>
</html>
