# Job Requirements Template
# Extract these from a job posting, ranked by importance
# Importance is determined by order: position 1 = 10, position 2 = 9, ... position 10 = 1
# The system will use only the top 5 most important summaries in the resume

requirements:
  - name: "Python"
  - name: "SQL"
  - name: "Problem Solving"
  - name: "API Development"
  - name: "Communication"
  - name: "Docker"
  - name: "AWS"
  - name: "Testing"
