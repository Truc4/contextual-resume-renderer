# Job Requirements Template
# Extract these from a job posting with importance weights
# importance: 1-10 (10 = most important)
# The system will use only the top 5 most important summaries in the resume

requirements:
  - name: "Python"
    importance: 10
  - name: "SQL"
    importance: 10
  - name: "API Development"
    importance: 9
  - name: "Docker"
    importance: 8
  - name: "AWS"
    importance: 8
  - name: "Testing"
    importance: 7
  - name: "Problem Solving"
    importance: 9
  - name: "Communication"
    importance: 8
