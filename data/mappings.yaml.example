# Mappings Configuration Template
#
# This file maps each requirement to how it appears on your resume.
# When a requirement appears in requirements.yaml, the system looks it up here and:
# 1. Collects any 'summary' text to include in SUMMARY section (top 5 by importance)
# 2. Marks items with 'skill: true' to include in SKILLS section
# 3. Uses 'either_or: "group"' to filter mutually exclusive skills
#
# Layout:
# requirement_name:
#   summary: "Text to appear in SUMMARY section"
#   skill: true                    # Include in SKILLS section
#   either_or: "group_name"        # Mutually exclusive group (only highest importance shown)
#
# Rules:
# - If a requirement has 'skill: true', it appears in SKILLS (case-sensitive)
# - If a requirement has 'summary:', that text appears in SUMMARY section
# - If a requirement has 'either_or: "group"', only one from the group is kept
#   (the one with highest importance in requirements.yaml)
# - A requirement can have multiple fields (e.g., both summary and skill)
#
# Example:
#   JavaScript:
#     skill: true
#     summary: "6+ years building applications with JavaScript across the full stack."
#     either_or: "js_family"

# Role requirements - map to summary text
software engineer:
  summary: "Software Engineer with 5+ years of full stack web development experience."
  either_or: software

software developer:
  summary: "Software Developer with 5+ years of full stack web development experience."
  either_or: software

application developer:
  summary: "Application Developer with 5+ years of full stack web development experience."
  either_or: software

web application developer:
  summary: "Web Application Developer with 5+ years of full stack web development experience."
  either_or: software

backend engineer:
  summary: "Backend Engineer specializing in server-side architecture and database design."
  either_or: backend

backend developer:
  summary: "Backend Developer specializing in server-side architecture and database design."
  either_or: backend

frontend engineer:
  summary: "Frontend Engineer with expertise in building responsive user interfaces."
  either_or: frontend

frontend developer:
  summary: "Frontend Developer with expertise in building responsive user interfaces."
  either_or: frontend

