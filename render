#!/bin/bash
# Simple render command — generates resume PDF from requirements.yaml + mappings.yaml

source venv/bin/activate

# Auto-detect requirements file
if [ -f "data/requirements.yaml" ]; then
  REQUIREMENTS_FILE="data/requirements.yaml"
elif [ -f "data/requirements.txt" ]; then
  REQUIREMENTS_FILE="data/requirements.txt"
else
  echo "Error: No requirements file found (data/requirements.yaml or data/requirements.txt)"
  exit 1
fi

python resume.py "$REQUIREMENTS_FILE" "$@"
